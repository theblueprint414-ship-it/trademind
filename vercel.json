{
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/circuit-breaker-reset",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/reminder",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/cron/onboarding-emails",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/behavioral-triggers",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/streak-recovery",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/auto-sync-journal",
      "schedule": "0 6 * * *"
    }
  ]
}