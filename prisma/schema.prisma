generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Auth (NextAuth v5) ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  plan           String    @default("free")
  tradeLimit     Int       @default(5)
  emailReminders Boolean   @default(true)
  traderType     String?
  dailyLossLimit Float?    // personal daily max loss ($)
  streakFreezeUsedAt String?  // ISO date of last freeze use (YYYY-MM)
  publicProfile  Boolean   @default(false)
  lsSubscriptionId String?
  lsCustomerId     String?
  onboardedAt    DateTime? // set when the user completes (or explicitly skips) onboarding
  createdAt      DateTime  @default(now())

  // Prop Firm Challenge Mode
  challengeEnabled          Boolean   @default(false)
  challengeFirm             String?
  challengeAccountSize      Float?
  challengeDailyLimit       Float?
  challengeMaxDrawdown      Float?
  challengeStartDate        String?
  challengeEndDate          String?
  challengeProfitTarget     Float?    // e.g. 10 (percent)
  challengeTradingDaysTarget Int?     // e.g. 4 (minimum days required)

  challengeAttempts     ChallengeAttempt[]

  accounts          Account[]
  tradingAccounts   TradingAccount[]
  sessions          Session[]
  checkins          Checkin[]
  trades            Trade[]
  tradeEntries      TradeEntry[]
  playbook          Playbook?
  brokerConnections BrokerConnection[]
  circuitBreaker    CircuitBreaker?
  cbOverrides       CircuitBreakerOverride[]
  dailyRecaps       DailyRecap[]
  referral          Referral?
  pushSubscriptions PushSubscription[]
  midSessionCheckins MidSessionCheckin[]
  preTradeRituals   PreTradeRitual[]
  partialCloses     PartialClose[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App Models ───────────────────────────────────────────────────────────

model Checkin {
  id        String   @id @default(cuid())
  userId    String
  date      String
  score     Int
  verdict   String
  answers   String
  // Lifestyle fields (added for mental patterns correlation)
  sleepQuality    Int?     // 1-10 subjective quality
  sleepHours      Float?   // hours slept
  caffeineLevel   String?  // "none"|"low"|"medium"|"high"
  alcoholLast24h  Boolean?
  exerciseToday   Boolean?
  tradingPlan     String?  // what setups/focus for today
  readinessScore  Int?     // 1-100 computed readiness (extends score)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model Trade {
  id       String   @id @default(cuid())
  userId   String
  date     String
  loggedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model BrokerConnection {
  id              String   @id @default(cuid())
  userId          String
  name            String?  // user-defined label, e.g. "FTMO Apex"
  broker          String   // "alpaca" | "binance" | "ibkr" | "bybit" | "tradovate" | "dxtrade"
  apiKey          String
  apiSecret       String?
  environment     String   @default("live") // "live" | "paper" | domain for DXTrade
  status          String   @default("active") // "active" | "error"
  startingBalance Float?   // account starting balance for % return calculation
  lastSyncAt      DateTime?
  createdAt       DateTime @default(now())

  tradeEntries TradeEntry[]
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TradeEntry {
  id            String   @id @default(cuid())
  userId        String
  date          String   // YYYY-MM-DD
  symbol        String?  // "AAPL", "BTC/USDT"
  side          String?  // "long" | "short"
  pnl           Float?   // profit/loss in $
  setup         String?  // trade thesis
  emotionBefore Int?     // 1-5
  emotionAfter  Int?     // 1-5
  mistake       String?  // what went wrong
  notes         String?
  checkinScore  Int?     // mental score that day
  tags          String?
  reflection    String?
  chartUrl      String?  // Vercel Blob URL of uploaded chart screenshot
  entryPrice    Float?
  exitPrice     Float?
  entryTime     String?  // ISO datetime
  exitTime      String?  // ISO datetime
  qty           Float?
  // ── Pro trade fields ───────────────────────────────────────────────────────
  stopLoss      Float?   // planned stop loss price
  takeProfit    Float?   // planned take profit price
  riskAmount    Float?   // $ risked on trade
  rMultiple     Float?   // realized R = pnl / riskAmount
  commission    Float?   // broker fees paid
  assetType     String?  // "futures" | "forex" | "crypto" | "stocks" | "options"
  plannedEntry  Float?   // planned entry vs actual
  duration      Int?     // seconds from entry to exit
  isPublic      Boolean  @default(false)
  // ICT/SMC structured tags + source tracking
  ictSetups          String?  // JSON array e.g. ["FVG","OB","BOS"]
  source             String?  // "manual"|"broker"|"csv"
  brokerTradeId      String?  // broker-side trade ID for dedup
  brokerConnectionId String?  // which BrokerConnection this came from
  mae                Float?   // Maximum Adverse Excursion ($)
  mfe                Float?   // Maximum Favorable Excursion ($)
  grade              String?  // A / B / C / D — auto-computed quality score
  // ── Options fields ─────────────────────────────────────────────────────────
  optionType   String?  // "call" | "put"
  strikePrice  Float?
  expiryDate   String?  // YYYY-MM-DD
  multiplier   Float?   // contract multiplier (100 for standard options, 50 for ES, etc.)
  // ── Account grouping ───────────────────────────────────────────────────────
  tradingAccountId String?
  // ── Trade context ──────────────────────────────────────────────────────────
  confidence       Int?     // 1–10 pre-trade conviction
  marketCondition  String?  // "trending" | "ranging" | "breakout" | "reversal"
  timeframe        String?  // "1m" | "5m" | "15m" | "1h" | "4h" | "1D"
  sessionType      String?  // "asian" | "london" | "new_york" | "overlap_london_ny"
  // ── Forex / futures extras ─────────────────────────────────────────────────
  lotSize          Float?   // lot size (forex)
  pips             Float?   // gain/loss in pips
  swap             Float?   // overnight swap cost
  // ── Multiple screenshots ───────────────────────────────────────────────────
  screenshotUrls   String?  // JSON array of {url, label, timeframe}
  createdAt          DateTime @default(now())

  brokerConnection BrokerConnection? @relation(fields: [brokerConnectionId], references: [id], onDelete: SetNull)
  tradingAccount   TradingAccount?   @relation(fields: [tradingAccountId], references: [id], onDelete: SetNull)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  partialCloses    PartialClose[]

  @@index([userId])
  @@index([userId, date])
  @@index([userId, tradingAccountId])
}

model PartialClose {
  id           String   @id @default(cuid())
  tradeEntryId String
  userId       String
  price        Float
  qty          Float
  pnl          Float?
  reason       String?  // "profit_taking" | "risk_reduction" | "trailing_stop" | "manual"
  closedAt     String   // ISO datetime
  notes        String?
  createdAt    DateTime @default(now())

  tradeEntry TradeEntry @relation(fields: [tradeEntryId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tradeEntryId])
  @@index([userId])
}

model TradingAccount {
  id              String   @id @default(cuid())
  userId          String
  name            String   // e.g. "FTMO Account 1", "Personal Prop"
  startingBalance Float?
  currency        String   @default("USD")
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeEntries TradeEntry[]

  @@index([userId])
}

model MidSessionCheckin {
  id          String   @id @default(cuid())
  userId      String
  date        String   // YYYY-MM-DD
  time        String   // HH:MM local time
  score       Int      // 1-10 pulse score
  mood        String   // "focused"|"anxious"|"tired"|"confident"|"frustrated"|"neutral"
  tradesCount Int      @default(0)
  note        String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Playbook {
  id        String   @id @default(cuid())
  userId    String   @unique
  rules     String   // JSON array of {id, text, category, enabled}
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  usedCount Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChallengeAttempt {
  id           String   @id @default(cuid())
  userId       String
  firm         String?
  accountSize  Float
  profitTarget Float?
  dailyLimit   Float
  maxDrawdown  Float
  tradingDaysTarget Int?
  startDate    String
  endDate      String?
  outcome      String?  // "passed" | "failed" | "active"
  finalPnl     Float?
  tradingDays  Int?
  notes        String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DailyRecap {
  id            String   @id @default(cuid())
  userId        String
  date          String   // YYYY-MM-DD
  mood          Int?     // 0=Rough 1=Okay 2=Good 3=Great
  pnl           Float?
  playbookScore Int?     // 0=Ignored 1=Mostly 2=Followed
  lesson        String?
  tradesCount   Int?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model CircuitBreaker {
  id              String   @id @default(cuid())
  userId          String   @unique
  isActive        Boolean  @default(false)
  dailyLimit      Int      @default(3)       // max trades per day
  scoreAdaptive   Boolean  @default(true)    // apply score-based multiplier
  resetHour       Int      @default(0)       // UTC hour to reset daily count (0 = midnight)
  extensionToken  String   @unique @default(cuid())
  blockedAt           DateTime?              // when limit was hit today
  tradeCountToday     Int      @default(0)   // cached count (refreshed on each check)
  blockedNotifiedDate  String?               // YYYY-MM-DD — last date a "blocked" push was sent (dedup)
  warningNotifiedDate  String?               // YYYY-MM-DD — last date a "1 trade left" push was sent (dedup)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CircuitBreakerOverride {
  id        String   @id @default(cuid())
  userId    String
  source    String   @default("extension") // "extension" | "dashboard"
  reason    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

model PreTradeRitual {
  id            String   @id @default(cuid())
  userId        String
  date          String   // YYYY-MM-DD
  setupType     String?  // primary ICT setup e.g. "FVG"
  conviction    Int?     // 1-10
  reason        String?  // "Why this trade?"
  hasStopLoss   Boolean  @default(false)
  linkedTradeId String?  // TradeEntry.id — filled in post-trade
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model AppError {
  id        String   @id @default(cuid())
  message   String
  stack     String?
  route     String?
  userId    String?
  context   String?  // JSON
  level     String   @default("error") // "error" | "warn"
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([level])
}
